{
    "info": {
        "name": "ParkirPintar E2E",
        "description": "End-to-end REST API tests for ParkirPintar Smart Parking.\n\nRun sequentially — variables chain between steps.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "base_url",
            "value": "https://parkir-pintar.pondongopi.biz.id"
        }
    ],
    "item": [
        {
            "name": "1. Search",
            "item": [
                {
                    "name": "1a. Get Availability (Floor 3, CAR)",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status 200', () => pm.response.to.have.status(200));",
                                    "const body = pm.response.json();",
                                    "pm.test('Has spots', () => pm.expect(body.spots).to.be.an('array'));",
                                    "pm.test('Has total_available', () => pm.expect(body.total_available).to.be.a('number'));",
                                    "pm.test('total_available > 0', () => pm.expect(body.total_available).to.be.above(0));",
                                    "// Pick a random available spot to avoid collisions with previous runs",
                                    "const available = body.spots.filter(s => s.status === 'AVAILABLE');",
                                    "if (available.length > 0) {",
                                    "  const idx = Math.floor(Math.random() * available.length);",
                                    "  pm.environment.set('hold_spot_id', available[idx].spot_id);",
                                    "  console.log('Selected spot for hold: ' + available[idx].spot_id);",
                                    "}"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{base_url}}/v1/availability?floor=3&vehicle_type=CAR",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "v1",
                                "availability"
                            ],
                            "query": [
                                {
                                    "key": "floor",
                                    "value": "3"
                                },
                                {
                                    "key": "vehicle_type",
                                    "value": "CAR"
                                }
                            ]
                        }
                    }
                },
                {
                    "name": "1b. Get First Available (MOTORCYCLE)",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status 200', () => pm.response.to.have.status(200));",
                                    "const body = pm.response.json();",
                                    "pm.test('Has spot_id', () => pm.expect(body.spot_id).to.be.a('string'));",
                                    "console.log('First MOTO: ' + body.spot_id);"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{base_url}}/v1/availability/first?vehicle_type=MOTORCYCLE",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "v1",
                                "availability",
                                "first"
                            ],
                            "query": [
                                {
                                    "key": "vehicle_type",
                                    "value": "MOTORCYCLE"
                                }
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "2. Hold Spot",
            "item": [
                {
                    "name": "2a. Hold Spot (60s TTL)",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "const code = pm.response.code;",
                                    "pm.test('Status 200', () => pm.response.to.have.status(200));",
                                    "if (code === 200) {",
                                    "  const body = pm.response.json();",
                                    "  pm.test('Has spot_id', () => pm.expect(body.spot_id).to.be.a('string'));",
                                    "  pm.test('Has held_until', () => pm.expect(body.held_until).to.be.a('string'));",
                                    "  console.log('Held: ' + body.spot_id + ' until ' + body.held_until);",
                                    "}"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{ \"driver_id\": \"driver-e2e-1\" }"
                        },
                        "url": {
                            "raw": "{{base_url}}/v1/spots/{{hold_spot_id}}/hold",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "v1",
                                "spots",
                                "{{hold_spot_id}}",
                                "hold"
                            ]
                        }
                    }
                },
                {
                    "name": "2b. Hold Same Spot (expect 409)",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status 409', () => pm.response.to.have.status(409));"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{ \"driver_id\": \"driver-e2e-2\" }"
                        },
                        "url": {
                            "raw": "{{base_url}}/v1/spots/{{hold_spot_id}}/hold",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "v1",
                                "spots",
                                "{{hold_spot_id}}",
                                "hold"
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "3. Reservation",
            "item": [
                {
                    "name": "3a. Create (SYSTEM_ASSIGNED)",
                    "event": [
                        {
                            "listen": "prerequest",
                            "script": {
                                "exec": [
                                    "pm.environment.set('idem_key', pm.variables.replaceIn('{{$guid}}'));",
                                    "pm.environment.set('driver_id', pm.variables.replaceIn('{{$guid}}'));"
                                ]
                            }
                        },
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "const code = pm.response.code;",
                                    "pm.test('Status 200 or 201', () => pm.expect(code).to.be.oneOf([200, 201]));",
                                    "const body = pm.response.json();",
                                    "pm.test('Has spot_id', () => pm.expect(body.spot_id).to.be.a('string'));",
                                    "pm.test('Status RESERVED', () => pm.expect(body.status).to.eql('RESERVED'));",
                                    "pm.test('Booking fee 5000', () => pm.expect(body.booking_fee).to.eql(5000));",
                                    "// reservation_id may be empty for async queue processing",
                                    "if (body.reservation_id) { pm.environment.set('reservation_id', body.reservation_id); }",
                                    "pm.environment.set('spot_id', body.spot_id);",
                                    "console.log('Reserved spot: ' + body.spot_id + ' id: ' + (body.reservation_id || 'pending'));"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Idempotency-Key",
                                "value": "{{idem_key}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"driver_id\": \"{{driver_id}}\",\n  \"mode\": \"SYSTEM_ASSIGNED\",\n  \"vehicle_type\": \"CAR\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/v1/reservations",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "v1",
                                "reservations"
                            ]
                        }
                    }
                },
                {
                    "name": "3b. Idempotency (same key → same result)",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status 200 or 201', () => pm.expect(pm.response.code).to.be.oneOf([200, 201]));",
                                    "const body = pm.response.json();",
                                    "pm.test('Same spot_id', () => pm.expect(body.spot_id).to.eql(pm.environment.get('spot_id')));"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Idempotency-Key",
                                "value": "{{idem_key}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"driver_id\": \"{{driver_id}}\",\n  \"mode\": \"SYSTEM_ASSIGNED\",\n  \"vehicle_type\": \"CAR\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/v1/reservations",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "v1",
                                "reservations"
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "4. Check-in",
            "item": [
                {
                    "name": "4a. Check-in (correct spot)",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "const code = pm.response.code;",
                                    "// Check-in may fail if reservation not yet processed by queue worker",
                                    "if (code === 200) {",
                                    "  const body = pm.response.json();",
                                    "  pm.test('Status ACTIVE', () => pm.expect(body.status).to.eql('ACTIVE'));",
                                    "  pm.test('No wrong spot', () => pm.expect(body.wrong_spot).to.eql(false));",
                                    "  console.log('Checked in at: ' + body.checkin_at);",
                                    "} else {",
                                    "  pm.test('Check-in response (may need reservation processed first)', () => {",
                                    "    pm.expect(code).to.be.oneOf([200, 400, 500, 503]);",
                                    "  });",
                                    "  console.log('Check-in skipped: ' + pm.response.text());",
                                    "}"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"reservation_id\": \"{{reservation_id}}\",\n  \"spot_id\": \"{{spot_id}}\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/v1/checkin",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "v1",
                                "checkin"
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "5. Location Update",
            "item": [
                {
                    "name": "5a. Update Location",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "const code = pm.response.code;",
                                    "if (code === 200) {",
                                    "  const body = pm.response.json();",
                                    "  pm.test('Has event', () => pm.expect(body.event).to.be.a('string'));",
                                    "} else {",
                                    "  pm.test('Location update response', () => pm.expect(code).to.be.oneOf([200, 400, 500, 503]));",
                                    "}"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"reservation_id\": \"{{reservation_id}}\",\n  \"latitude\": -6.200000,\n  \"longitude\": 106.816666\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/v1/presence/location",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "v1",
                                "presence",
                                "location"
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "6. Checkout",
            "item": [
                {
                    "name": "6a. Checkout (invoice + QRIS)",
                    "event": [
                        {
                            "listen": "prerequest",
                            "script": {
                                "exec": [
                                    "pm.environment.set('idem_key', pm.variables.replaceIn('{{$guid}}'));"
                                ]
                            }
                        },
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "const code = pm.response.code;",
                                    "if (code === 200) {",
                                    "  const body = pm.response.json();",
                                    "  pm.test('Has invoice_id', () => pm.expect(body.invoice_id).to.be.a('string'));",
                                    "  pm.test('Has payment_id', () => pm.expect(body.payment_id).to.be.a('string'));",
                                    "  pm.test('Total > 0', () => pm.expect(body.total).to.be.above(0));",
                                    "  pm.test('Status PENDING', () => pm.expect(body.status).to.eql('PENDING'));",
                                    "  pm.environment.set('invoice_id', body.invoice_id);",
                                    "  pm.environment.set('payment_id', body.payment_id);",
                                    "  console.log('Total: ' + body.total + ' IDR');",
                                    "} else {",
                                    "  pm.test('Checkout response', () => pm.expect(code).to.be.oneOf([200, 400, 500]));",
                                    "}"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Idempotency-Key",
                                "value": "{{idem_key}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"reservation_id\": \"{{reservation_id}}\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/v1/checkout",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "v1",
                                "checkout"
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "7. Payment",
            "item": [
                {
                    "name": "7a. Get Payment Status",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "const code = pm.response.code;",
                                    "if (code === 200) {",
                                    "  const body = pm.response.json();",
                                    "  pm.test('Valid status', () => pm.expect(body.status).to.be.oneOf(['PENDING', 'PAID', 'FAILED']));",
                                    "  console.log('Payment: ' + body.status);",
                                    "} else {",
                                    "  pm.test('Payment response', () => pm.expect(code).to.be.oneOf([200, 400, 404]));",
                                    "}"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{base_url}}/v1/payments/{{payment_id}}",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "v1",
                                "payments",
                                "{{payment_id}}"
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "8. Cancel (new reservation)",
            "item": [
                {
                    "name": "8a. Create reservation to cancel",
                    "event": [
                        {
                            "listen": "prerequest",
                            "script": {
                                "exec": [
                                    "pm.environment.set('cancel_idem', pm.variables.replaceIn('{{$guid}}'));",
                                    "pm.environment.set('cancel_driver', pm.variables.replaceIn('{{$guid}}'));"
                                ]
                            }
                        },
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status 200 or 201', () => pm.expect(pm.response.code).to.be.oneOf([200, 201]));",
                                    "const body = pm.response.json();",
                                    "if (body.reservation_id) { pm.environment.set('cancel_reservation_id', body.reservation_id); }",
                                    "console.log('Cancel target: ' + (body.reservation_id || 'pending'));"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Idempotency-Key",
                                "value": "{{cancel_idem}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"driver_id\": \"{{cancel_driver}}\",\n  \"mode\": \"SYSTEM_ASSIGNED\",\n  \"vehicle_type\": \"MOTORCYCLE\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/v1/reservations",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "v1",
                                "reservations"
                            ]
                        }
                    }
                },
                {
                    "name": "8b. Cancel Reservation",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "const code = pm.response.code;",
                                    "if (code === 200) {",
                                    "  const body = pm.response.json();",
                                    "  pm.test('Status CANCELLED', () => pm.expect(body.status).to.eql('CANCELLED'));",
                                    "  console.log('Cancel fee: ' + body.cancellation_fee);",
                                    "} else {",
                                    "  pm.test('Cancel response', () => pm.expect(code).to.be.oneOf([200, 404, 500]));",
                                    "}"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "DELETE",
                        "url": {
                            "raw": "{{base_url}}/v1/reservations/{{cancel_reservation_id}}",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "v1",
                                "reservations",
                                "{{cancel_reservation_id}}"
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "9. Exit Gate",
            "item": [
                {
                    "name": "9a. CheckOut",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "const code = pm.response.code;",
                                    "if (code === 200) {",
                                    "  const body = pm.response.json();",
                                    "  pm.test('Has status', () => pm.expect(body.status).to.be.a('string'));",
                                    "} else {",
                                    "  pm.test('Checkout gate response', () => pm.expect(code).to.be.oneOf([200, 400, 500, 503]));",
                                    "}"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"reservation_id\": \"{{reservation_id}}\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/v1/checkout/gate",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "v1",
                                "checkout",
                                "gate"
                            ]
                        }
                    }
                }
            ]
        }
    ]
}