{
  "uid": "parkir-overview",
  "title": "Parkir Pintar - Service Overview",
  "tags": [
    "parkir-pintar",
    "overview"
  ],
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(istio_requests_total{destination_workload_namespace=\"parkir-pintar\", destination_service_name!=\"\"}, destination_service_name)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(istio_requests_total{destination_workload_namespace=\"parkir-pintar\", destination_service_name=~\"$service\"}[5m])) by (destination_service_name)",
          "legendFormat": "{{destination_service_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Error Rate (5xx)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(istio_requests_total{destination_workload_namespace=\"parkir-pintar\", destination_service_name=~\"$service\", response_code=~\"5.*\"}[5m])) by (destination_service_name)",
          "legendFormat": "{{destination_service_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 3,
      "title": "P50 Latency",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(istio_request_duration_milliseconds_bucket{destination_workload_namespace=\"parkir-pintar\", destination_service_name=~\"$service\", reporter=\"destination\"}[5m])) by (le, destination_service_name))",
          "legendFormat": "{{destination_service_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      }
    },
    {
      "id": 4,
      "title": "P95 Latency",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(istio_request_duration_milliseconds_bucket{destination_workload_namespace=\"parkir-pintar\", destination_service_name=~\"$service\", reporter=\"destination\"}[5m])) by (le, destination_service_name))",
          "legendFormat": "{{destination_service_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      }
    },
    {
      "id": 5,
      "title": "P99 Latency",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(istio_request_duration_milliseconds_bucket{destination_workload_namespace=\"parkir-pintar\", destination_service_name=~\"$service\", reporter=\"destination\"}[5m])) by (le, destination_service_name))",
          "legendFormat": "{{destination_service_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      }
    },
    {
      "id": 6,
      "title": "Success Rate (%)",
      "type": "gauge",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(istio_requests_total{destination_workload_namespace=\"parkir-pintar\", destination_service_name=~\"$service\", response_code!~\"5.*\"}[5m])) by (destination_service_name) / sum(rate(istio_requests_total{destination_workload_namespace=\"parkir-pintar\", destination_service_name=~\"$service\"}[5m])) by (destination_service_name) * 100",
          "legendFormat": "{{destination_service_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 95
              },
              {
                "color": "green",
                "value": 99
              }
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "title": "gRPC Method Calls (Beyla)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(rpc_server_duration_seconds_count{server_port=\"50051\", rpc_method!~\"/grpc.health.*|/rpc.CNI.*|/envoy.*\"}[5m])) by (rpc_method)",
          "legendFormat": "{{rpc_method}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      }
    },
    {
      "id": 8,
      "title": "HTTP Gateway Request Rate (Beyla)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 24
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_request_duration_seconds_count{server_port=\"8080\", http_route!~\"/health|/ready|/metrics|/\\\\*.*\"}[5m])) by (http_route)",
          "legendFormat": "{{http_route}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      }
    },
    {
      "id": 9,
      "title": "HTTP Gateway Latency P95 (Beyla)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 24
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_request_duration_seconds_bucket{server_port=\"8080\"}[5m])) by (le))",
          "legendFormat": "p95 gateway",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "id": 10,
      "title": "gRPC Response Codes",
      "type": "piechart",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 32
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(increase(istio_requests_total{destination_workload_namespace=\"parkir-pintar\", destination_service_name=~\"$service\"}[1h])) by (response_code)",
          "legendFormat": "{{response_code}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "title": "Request Volume by Service (1h)",
      "type": "bargauge",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 32
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(increase(istio_requests_total{destination_workload_namespace=\"parkir-pintar\"}[1h])) by (destination_service_name)",
          "legendFormat": "{{destination_service_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 12,
      "title": "Service Logs",
      "type": "logs",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 40
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "{namespace=\"parkir-pintar\"}",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39
}