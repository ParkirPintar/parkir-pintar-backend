{
  "uid": "parkir-analytics",
  "title": "Parkir Pintar - Business Analytics",
  "tags": [
    "parkir-pintar",
    "analytics",
    "business"
  ],
  "timezone": "browser",
  "refresh": "1m",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "event_type",
        "type": "query",
        "datasource": {
          "type": "postgres",
          "uid": "analytics-db"
        },
        "query": "SELECT DISTINCT event_type FROM transaction_events ORDER BY event_type",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Total Events Today",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "postgres",
        "uid": "analytics-db"
      },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) AS \"Total Events\" FROM transaction_events WHERE recorded_at >= NOW() - INTERVAL '24 hours'",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 2,
      "title": "Reservations Today",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 0
      },
      "datasource": {
        "type": "postgres",
        "uid": "analytics-db"
      },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) AS \"Reservations\" FROM transaction_events WHERE event_type = 'reservation.confirmed' AND recorded_at >= NOW() - INTERVAL '24 hours'",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Check-ins Today",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 8,
        "y": 0
      },
      "datasource": {
        "type": "postgres",
        "uid": "analytics-db"
      },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) AS \"Check-ins\" FROM transaction_events WHERE event_type = 'checkin.confirmed' AND recorded_at >= NOW() - INTERVAL '24 hours'",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Checkouts Today",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "postgres",
        "uid": "analytics-db"
      },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) AS \"Checkouts\" FROM transaction_events WHERE event_type = 'checkout.completed' AND recorded_at >= NOW() - INTERVAL '24 hours'",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "fixed",
            "fixedColor": "purple"
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Revenue Today (IDR)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 16,
        "y": 0
      },
      "datasource": {
        "type": "postgres",
        "uid": "analytics-db"
      },
      "targets": [
        {
          "rawSql": "SELECT COALESCE(SUM(amount), 0) AS \"Revenue\" FROM transaction_events WHERE event_type IN ('checkout.completed', 'reservation.confirmed') AND recorded_at >= NOW() - INTERVAL '24 hours'",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyIDR"
        }
      }
    },
    {
      "id": 6,
      "title": "Cancellations / Errors",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 20,
        "y": 0
      },
      "datasource": {
        "type": "postgres",
        "uid": "analytics-db"
      },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) AS \"Issues\" FROM transaction_events WHERE event_type IN ('reservation.cancelled', 'reservation.expired', 'checkout.failed', 'penalty.applied') AND recorded_at >= NOW() - INTERVAL '24 hours'",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "fixed",
            "fixedColor": "red"
          }
        }
      }
    },
    {
      "id": 7,
      "title": "Events Over Time",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 4
      },
      "datasource": {
        "type": "postgres",
        "uid": "analytics-db"
      },
      "targets": [
        {
          "rawSql": "SELECT $__timeGroup(recorded_at, '5m') AS time, event_type, COUNT(*) AS count FROM transaction_events WHERE $__timeFilter(recorded_at) AND event_type IN ($event_type) GROUP BY time, event_type ORDER BY time",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "stacking": {
              "mode": "normal"
            }
          }
        }
      }
    },
    {
      "id": 8,
      "title": "Revenue Over Time",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "datasource": {
        "type": "postgres",
        "uid": "analytics-db"
      },
      "targets": [
        {
          "rawSql": "SELECT $__timeGroup(recorded_at, '1h') AS time, SUM(amount) AS revenue FROM transaction_events WHERE $__timeFilter(recorded_at) AND amount > 0 GROUP BY time ORDER BY time",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyIDR",
          "custom": {
            "fillOpacity": 20
          }
        }
      }
    },
    {
      "id": 9,
      "title": "Events by Type (Pie)",
      "type": "piechart",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "datasource": {
        "type": "postgres",
        "uid": "analytics-db"
      },
      "targets": [
        {
          "rawSql": "SELECT event_type AS metric, COUNT(*) AS value FROM transaction_events WHERE $__timeFilter(recorded_at) GROUP BY event_type ORDER BY value DESC",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "title": "Top Spots by Usage",
      "type": "bargauge",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 20
      },
      "datasource": {
        "type": "postgres",
        "uid": "analytics-db"
      },
      "targets": [
        {
          "rawSql": "SELECT spot_id, COUNT(*) AS usage FROM transaction_events WHERE $__timeFilter(recorded_at) AND spot_id IS NOT NULL AND spot_id != '' GROUP BY spot_id ORDER BY usage DESC LIMIT 15",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 11,
      "title": "Vehicle Type Distribution",
      "type": "piechart",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 20
      },
      "datasource": {
        "type": "postgres",
        "uid": "analytics-db"
      },
      "targets": [
        {
          "rawSql": "SELECT vehicle_type AS metric, COUNT(*) AS value FROM transaction_events WHERE $__timeFilter(recorded_at) AND vehicle_type IS NOT NULL AND vehicle_type != '' GROUP BY vehicle_type",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 12,
      "title": "Hourly Occupancy Pattern",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 28
      },
      "datasource": {
        "type": "postgres",
        "uid": "analytics-db"
      },
      "targets": [
        {
          "rawSql": "SELECT $__timeGroup(recorded_at, '1h') AS time, COUNT(*) AS checkins FROM transaction_events WHERE $__timeFilter(recorded_at) AND event_type = 'checkin.confirmed' GROUP BY time ORDER BY time",
          "format": "time_series",
          "refId": "A"
        },
        {
          "rawSql": "SELECT $__timeGroup(recorded_at, '1h') AS time, COUNT(*) AS checkouts FROM transaction_events WHERE $__timeFilter(recorded_at) AND event_type = 'checkout.completed' GROUP BY time ORDER BY time",
          "format": "time_series",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 15
          }
        }
      }
    },
    {
      "id": 13,
      "title": "Average Revenue per Transaction",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 0,
        "y": 36
      },
      "datasource": {
        "type": "postgres",
        "uid": "analytics-db"
      },
      "targets": [
        {
          "rawSql": "SELECT COALESCE(AVG(amount), 0) AS \"Avg Revenue\" FROM transaction_events WHERE $__timeFilter(recorded_at) AND amount > 0",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyIDR"
        }
      }
    },
    {
      "id": 14,
      "title": "Unique Drivers Today",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 8,
        "y": 36
      },
      "datasource": {
        "type": "postgres",
        "uid": "analytics-db"
      },
      "targets": [
        {
          "rawSql": "SELECT COUNT(DISTINCT driver_id) AS \"Unique Drivers\" FROM transaction_events WHERE recorded_at >= NOW() - INTERVAL '24 hours'",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 15,
      "title": "Cancellation Rate (%)",
      "type": "gauge",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 16,
        "y": 36
      },
      "datasource": {
        "type": "postgres",
        "uid": "analytics-db"
      },
      "targets": [
        {
          "rawSql": "SELECT CASE WHEN total = 0 THEN 0 ELSE (cancelled::float / total * 100) END AS \"Cancel Rate\" FROM (SELECT COUNT(*) FILTER (WHERE event_type IN ('reservation.cancelled', 'reservation.expired')) AS cancelled, COUNT(*) AS total FROM transaction_events WHERE recorded_at >= NOW() - INTERVAL '24 hours') sub",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 10
              },
              {
                "color": "red",
                "value": 25
              }
            ]
          }
        }
      }
    },
    {
      "id": 16,
      "title": "Recent Events",
      "type": "table",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 40
      },
      "datasource": {
        "type": "postgres",
        "uid": "analytics-db"
      },
      "targets": [
        {
          "rawSql": "SELECT recorded_at AS \"Time\", event_type AS \"Event\", spot_id AS \"Spot\", vehicle_type AS \"Vehicle\", amount AS \"Amount (IDR)\", driver_id AS \"Driver\" FROM transaction_events WHERE $__timeFilter(recorded_at) ORDER BY recorded_at DESC LIMIT 50",
          "format": "table",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39
}