            "content": {
                "expressions": [
                    {
                        "id": "on_e1",
                        "key": "overnightFee",
                        "value": "midnightCrossings > 0 ? midnightCrossings * 20000 : 0"
                    }
                ],
                "passThrough": true,
                "inputField": null,
                "outputPath": null,
                "executionMode": "single"
            }
        },
