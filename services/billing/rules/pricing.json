            "position": {
                "x": 500,
                "y": 50
            },
            "content": {
                "expressions": [
                    {
                        "id": "hf_e1",
                        "key": "hourlyFee",
                        "value": "durationHours > 0 ? ceil(durationHours) * 5000 : 0"
                    }
                ],
                "passThrough": true,
                "inputField": null,
                "outputPath": null,
                "executionMode": "single"
            }
        },
        {
